        "jsCode": "// Filter jobs for Lahore and Faisalabad - FREE, no AI needed!\nconst items = $input.all();\n\nconst cities = ['lahore', 'faisalabad'];\nconst keywords = ['intern', 'internship', 'trainee', 'apprentice', \n                  'developer', 'data', 'software', 'web', 'php',\n                  'python', 'machine learning', 'ai', 'automation',\n                  'sqa', 'computer vision', 'design'];\n\nconst filtered = items.filter(item => {\n  const location = (item.json.location || '').toLowerCase();\n  const title = (item.json.title || '').toLowerCase();\n  const desc = (item.json.description || '').toLowerCase();\n  \n  // Check if location is Lahore or Faisalabad\n  const cityMatch = cities.some(city => location.includes(city));\n  \n  return cityMatch; // Keep all jobs in Lahore/Faisalabad\n});\n\nreturn filtered.length > 0 \n  ? filtered \n  : [{ json: { noResults: true, message: 'No jobs found today' } }];"
      },
