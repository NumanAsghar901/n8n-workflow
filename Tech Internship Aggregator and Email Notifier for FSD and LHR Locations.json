    {
      "parameters": {
        "jsCode": "// Parse LinkedIn HTML response and extract job listings\nconst items = $input.all();\nconst outputItems = [];\n\nfor (const item of items) {\n  const html = item.json.data || item.json.body || '';\n  \n  // Use regex to extract job listings from LinkedIn HTML\n  // LinkedIn job cards typically have specific class patterns\n  const jobPattern = /<li[^>]*>([\\s\\S]*?)<\\/li>/gi;\n  const matches = html.matchAll(jobPattern);\n  \n  for (const match of matches) {\n    const jobHtml = match[1];\n    \n    // Extract title\n    const titleMatch = jobHtml.match(/<h3[^>]*class=\"[^\"]*base-search-card__title[^\"]*\"[^>]*>([\\s\\S]*?)<\\/h3>/i);\n    const title = titleMatch ? titleMatch[1].trim().replace(/<[^>]*>/g, '').trim() : '';\n    \n    // Extract company\n    const companyMatch = jobHtml.match(/<h4[^>]*class=\"[^\"]*base-search-card__subtitle[^\"]*\"[^>]*>([\\s\\S]*?)<\\/h4>/i) || \n                        jobHtml.match(/<a[^>]*class=\"[^\"]*hidden-nested-link[^\"]*\"[^>]*>([\\s\\S]*?)<\\/a>/i);\n    const company = companyMatch ? companyMatch[1].trim().replace(/<[^>]*>/g, '').trim() : '';\n    \n    // Extract location\n    const locationMatch = jobHtml.match(/<span[^>]*class=\"[^\"]*job-search-card__location[^\"]*\"[^>]*>([\\s\\S]*?)<\\/span>/i);\n    const location = locationMatch ? locationMatch[1].trim().replace(/<[^>]*>/g, '').trim() : '';\n    \n    // Extract link\n    const linkMatch = jobHtml.match(/<a[^>]*href=\"([^\"]*)\"/i);\n    const link = linkMatch ? linkMatch[1].trim() : '';\n    \n    // Only add if we have at least a title\n    if (title) {\n      outputItems.push({\n        json: {\n          title: title,\n          company: company,\n          location: location,\n          link: link,\n          source: 'LinkedIn'\n        }\n      });\n    }\n  }\n}\n\nreturn outputItems.length > 0 ? outputItems : [{ json: { message: 'No jobs found' } }];"
      },
